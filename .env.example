# Duffel sandbox access token — create one at https://app.duffel.com (Developers → Access tokens).
# Copy this file to .env and paste your token. Sandbox tokens start with duffel_test_.
#
# Deliberately NOT prefixed with VITE_: the token is read only by server-side code
# (the Vite dev proxy locally, the Vercel serverless function in production) and can
# never end up in the client bundle.
DUFFEL_ACCESS_TOKEN=duffel_test_replace_me
